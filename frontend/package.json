{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "coverage": "vitest run --coverage",
    "coverage:check": "node ../scripts/check-coverage.mjs",
    "coverage:ci": "pnpm coverage && pnpm coverage:check",
    "codegen": "pnpm exec openapi-typescript http://localhost:3000/doc -o ./src/types/backend-schema.d.ts",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "@sentry/react": "^10.48.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.167.4",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "posthog-js": "^1.368.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/router-plugin": "^1.167.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "openapi-typescript": "^7.13.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0"
  }
}