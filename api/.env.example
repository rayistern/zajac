# Copy to .env.dev and fill in. .env.dev is gitignored.

# --- Postgres ---
# For local Docker postgres (docker compose up -d):
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=app
DB_USER=postgres
DB_PASS=postgres

# --- Vercel AI Gateway ---
# Required for any route that hits the gateway in dev (chatbot, summarise, …).
# Tests never need this — they go through the mock provider automatically.
# Grab a key from https://vercel.com/dashboard → AI → Gateway.
AI_GATEWAY_API_KEY=

# --- Optional ---
# NODE_ENV=development  # default; set to "test" to force mock AI branch locally
