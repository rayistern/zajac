# =============================================================================
# Podcast Pipeline — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual keys.
# NEVER commit .env to version control.

# --- Transcription ---
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here
OPENAI_API_KEY=your_openai_api_key_here          # used for Whisper and/or DALL-E
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# --- LLM (chapter splitting + prompt generation) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY already declared above — shared for LLM + image generation
GOOGLE_API_KEY=your_google_gemini_api_key_here

# --- Image Generation ---
STABILITY_API_KEY=your_stability_ai_api_key_here
REPLICATE_API_TOKEN=your_replicate_api_token_here

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here       # e.g. -1001234567890 for a group
