# Copy to .env and fill in. .env is gitignored.

# --- Pipeline database (Alembic-managed) ---
# Ships as a separate container on port 5433 in local dev so it never collides
# with the frontend DB.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/app

# --- LLM provider cascade (src/pipeline/llm.py) ---
# Resolution order: AI_GATEWAY_API_KEY -> OPENROUTER_API_KEY -> ANTHROPIC_API_KEY.
# Set whichever you have; the pipeline picks the first present key.
#
# Preferred in 2026+: Vercel AI Gateway. Same key as the api/.env.example one.
AI_GATEWAY_API_KEY=
# Legacy: OpenRouter. Kept for hand-rolled runs that still point at it.
OPENROUTER_API_KEY=
# Fallback: direct Anthropic. Only fires when neither gateway key is set.
ANTHROPIC_API_KEY=

# --- Image generation ---
# Required for the artifact_version.url column to resolve to a real asset.
REPLICATE_API_TOKEN=

# --- Frontend DB (for publisher.py) ---
# The publisher reads pipeline tables and writes content_item rows via a
# separate connection. Defaults to the api/.env.dev values if unset.
# FRONTEND_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app
